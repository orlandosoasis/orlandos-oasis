# Lovable Cloud auto-injects these at build time. Do not commit real values.
VITE_SUPABASE_PROJECT_ID=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_URL=

# Cloudflare Turnstile (CAPTCHA) site key. Public, safe to commit, but kept
# out of git by convention. See docs/FORMS_HARDENING.md for setup.
VITE_TURNSTILE_SITE_KEY=
